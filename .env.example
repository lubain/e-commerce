# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lumiere_db?schema=public"

# ─── NextAuth v5 ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-min-32-chars"
AUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a new project (or select existing)
# 3. Enable "Google+ API" or "Google Identity"
# 4. Go to APIs & Services > Credentials
# 5. Create OAuth 2.0 Client ID (Web application)
# 6. Add Authorized redirect URIs:
#    - http://localhost:3000/api/auth/callback/google  (development)
#    - https://yourdomain.com/api/auth/callback/google  (production)
AUTH_GOOGLE_ID="xxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxx"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Production only ──────────────────────────────────────────────────────────
# Needed when deploying behind a proxy (Vercel, etc.)
AUTH_TRUST_HOST=true
